#!/usr/bin/env bash
set -euo pipefail

FORGE_CONFIG_DIR="${FORGE_CONFIG_DIR:-$HOME/.forge/config}"
FORGE_PORTS_FILE="$HOME/.forge/ports"
FORGE_DEFAULT_SECRETS="${FORGE_DEFAULT_SECRETS:-$FORGE_CONFIG_DIR/.secrets}"
PORT_START="${FORGE_PORT_START:-8889}"

# Template path: Homebrew install → /opt/homebrew/share/forge/templates
# Local dev → $HOME/.forge/templates
if [[ -d "${HOMEBREW_PREFIX:-}/share/forge/templates" ]]; then
    FORGE_TEMPLATES_DIR="${HOMEBREW_PREFIX}/share/forge/templates"
elif [[ -d "$HOME/.forge/templates" ]]; then
    FORGE_TEMPLATES_DIR="$HOME/.forge/templates"
else
    FORGE_TEMPLATES_DIR="$HOME/.forge/templates"
fi

# Global arrays for secrets
SECRET_KEYS=()
SECRET_VALS=()

# Bootstrap templates on first run (outside Homebrew)
bootstrap_templates() {
    if [[ -d "$FORGE_TEMPLATES_DIR/shared" ]]; then return 0; fi
    local script_dir parent bundled
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    parent="$(dirname "$script_dir")"

    # Homebrew: ../share/forge/templates  |  dev: ../templates
    for bundled in "$parent/share/forge/templates" "$parent/templates"; do
        if [[ -d "$bundled/shared" ]]; then
            mkdir -p "$FORGE_TEMPLATES_DIR"
            cp -r "$bundled"/* "$FORGE_TEMPLATES_DIR/"
            return 0
        fi
    done

    echo "Error: forge templates not found." >&2
    echo "  Looked under: $parent" >&2
    exit 1
}

# --- helpers ---

usage() {
    cat <<EOF
Usage: forge <command> [OPTIONS] [ARGS]

Commands:
  init [project]   Create GitHub + Docker Hub repos, scaffold project from templates
  sync             Sync secrets from .secrets file to an existing GitHub repo
  destroy [project] Delete remote GitHub + Docker Hub repos and the local directory

Options:
  --secrets PATH     Path to .secrets file
                     (default: \$FORGE_CONFIG_DIR/.secrets → \$PWD/.secrets)
  --name NAME        Repository name (default: directory name)
  --port PORT        Host port (default: auto-assign from $PORT_START)
  --visibility TYPE  GitHub repo visibility (init only): private (default), public
  -h, --help         Show this help

Examples:
  forge init my-app
  forge init my-app --port 9000 --visibility public
  forge init                    # init in current directory
  forge sync
  forge sync --name owner/repo
  forge destroy my-app
  forge destroy
EOF
    exit 0
}

resolve_secrets_file() {
    local file="$1"
    if [[ -n "$file" ]]; then
        echo "$file"
    elif [[ -f "$FORGE_DEFAULT_SECRETS" ]]; then
        echo "$FORGE_DEFAULT_SECRETS"
    elif [[ -f "$PWD/.secrets" ]]; then
        echo "$PWD/.secrets"
    else
        echo "Error: No .secrets file found." >&2
        echo "  Looked at: $FORGE_DEFAULT_SECRETS, $PWD/.secrets" >&2
        exit 1
    fi
}

load_secrets() {
    local file="$1"
    SECRET_KEYS=()
    SECRET_VALS=()
    while IFS='=' read -r key value; do
        key="${key//[[:space:]]/}"
        [[ -z "$key" || "$key" == \#* ]] && continue
        value="${value#"${value%%[![:space:]]*}"}"
        value="${value%"${value##*[![:space:]]}"}"
        SECRET_KEYS+=("$key")
        SECRET_VALS+=("$value")
    done < "$file"
}

get_secret() {
    local target="$1" i
    for i in "${!SECRET_KEYS[@]}"; do
        if [[ "${SECRET_KEYS[$i]}" == "$target" ]]; then
            echo "${SECRET_VALS[$i]}"
            return
        fi
    done
}

check_prereqs() {
    local cmd
    for cmd in gh curl jq; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo "Error: '$cmd' not found. Please install it first." >&2
            exit 1
        fi
    done
    if ! gh auth status >/dev/null 2>&1; then
        echo "Error: not authenticated with GitHub CLI. Run: gh auth login" >&2
        exit 1
    fi
}

set_github_secrets() {
    local repo="$1" i key val
    for i in "${!SECRET_KEYS[@]}"; do
        key="${SECRET_KEYS[$i]}"
        val="${SECRET_VALS[$i]}"
        # Auto-decode base64 values: DEPLOY_SSH_KEY_BASE64 → DEPLOY_SSH_KEY (decoded)
        if [[ "$key" == *_BASE64 ]]; then
            key="${key%_BASE64}"
            val=$(echo "$val" | base64 -d 2>/dev/null || echo "$val")
        fi
        printf "  %-30s ... " "$key"
        gh secret set "$key" --repo "$repo" --body "$val"
        echo "done"
    done
}

# Port registry: ~/.forge/ports  (one "project:port" per line)
port_of()   { awk -F: -v n="$1" '$1 == n { print $2; exit }' "$FORGE_PORTS_FILE" 2>/dev/null; }
owner_of()  { awk -F: -v p="$1" '$2 == p { print $1; exit }' "$FORGE_PORTS_FILE" 2>/dev/null; }
port_used() { awk -F: -v p="$1" '$2 == p { exit 0 } END { exit 1 }' "$FORGE_PORTS_FILE" 2>/dev/null; }

port_assign() {
    local name="$1" want="${2:-}"
    [[ -z "$name" ]] && { echo "Error: port_assign requires a project name" >&2; exit 1; }

    # --port given: validate conflict, then register
    if [[ -n "$want" ]]; then
        local owner
        owner=$(owner_of "$want")
        if [[ -n "$owner" && "$owner" != "$name" ]]; then
            echo "Error: port $want is already assigned to '$owner'" >&2; exit 1
        fi
        port_register "$name" "$want"
        echo "$want"
        return
    fi

    # Reuse existing assignment
    local existing
    existing=$(port_of "$name")
    if [[ -n "$existing" ]]; then
        echo "$existing"
        return
    fi

    # Find first free port from PORT_START
    local p="$PORT_START"
    while port_used "$p"; do
        p=$((p + 1))
    done
    port_register "$name" "$p"
    echo "$p"
}

port_register() {
    local name="$1" port="$2"
    mkdir -p "$(dirname "$FORGE_PORTS_FILE")"
    # Remove old entry for this project (if any), then append
    if [[ -f "$FORGE_PORTS_FILE" ]]; then
        grep -v "^$name:" "$FORGE_PORTS_FILE" > "$FORGE_PORTS_FILE.tmp" 2>/dev/null || true
        mv "$FORGE_PORTS_FILE.tmp" "$FORGE_PORTS_FILE"
    fi
    echo "$name:$port" >> "$FORGE_PORTS_FILE"
}

port_release() {
    local name="$1"
    if [[ -f "$FORGE_PORTS_FILE" ]]; then
        grep -v "^$name:" "$FORGE_PORTS_FILE" > "$FORGE_PORTS_FILE.tmp" 2>/dev/null || true
        mv "$FORGE_PORTS_FILE.tmp" "$FORGE_PORTS_FILE"
    fi
}

render_template() {
    local src="$1" dst="$2"
    local image_name="$3" container_name="$4" host_port="$5" container_port="$6" deploy_root="$7"
    sed \
        -e "s|{{IMAGE_NAME}}|$image_name|g" \
        -e "s|{{CONTAINER_NAME}}|$container_name|g" \
        -e "s|{{HOST_PORT}}|$host_port|g" \
        -e "s|{{CONTAINER_PORT}}|$container_port|g" \
        -e "s|{{DEPLOY_ROOT}}|$deploy_root|g" \
        "$src" > "$dst"
}

# --- Docker Hub ---

dockerhub_auth() {
    local namespace="$1" token="$2"
    local login_resp jwt
    login_resp=$(curl -s --connect-timeout 15 -X POST https://hub.docker.com/v2/users/login/ \
        -H "Content-Type: application/json" \
        -d "{\"username\":\"$namespace\",\"password\":\"$token\"}" 2>&1) || true
    jwt=$(echo "$login_resp" | jq -r '.token' 2>/dev/null || true)
    if [[ -z "$jwt" || "$jwt" == "null" ]]; then
        echo ""
    else
        echo "$jwt"
    fi
}

create_dockerhub_repo() {
    local namespace="$1" name="$2" token="$3"

    # Docker Hub API blocks PAT-issued JWTs for repo creation (github.com/docker/roadmap/issues/388).
    # The repo will be auto-created by 'docker push' on first CI deploy.
    # Visibility (private/public) must be set manually at:
    #   https://hub.docker.com/repository/create?namespace=$namespace
    echo "  Skipped: Docker Hub API blocks PAT-based repo creation" >&2
    echo "  Repo will be auto-created on first 'docker push'." >&2
    echo "  Set visibility manually if needed: https://hub.docker.com/settings/security" >&2
}

delete_dockerhub_repo() {
    local namespace="$1" name="$2" token="$3"

    local jwt
    jwt=$(dockerhub_auth "$namespace" "$token")
    if [[ -z "$jwt" ]]; then
        echo "  Skipped: Docker Hub login failed" >&2
        return 0
    fi

    local http_code
    http_code=$(curl -s --connect-timeout 15 -o /dev/null -w "%{http_code}" \
        -X DELETE "https://hub.docker.com/v2/namespaces/$namespace/repositories/$name/" \
        -H "Authorization: Bearer $jwt") || true

    case "${http_code:-000}" in
        204|202) echo "  Deleted: docker.io/$namespace/$name" ;;
        404)     echo "  Not found (already deleted): docker.io/$namespace/$name" ;;
        000)     echo "  Skipped: Docker Hub API unreachable" >&2 ;;
        *)       echo "  Warning: unexpected HTTP status $http_code" >&2 ;;
    esac
}

resolve_gh_repo() {
    local target_dir="$1" repo_name="$2"
    local gh_repo=""
    if [[ -d "$target_dir/.git" ]]; then
        gh_repo="$(git -C "$target_dir" remote get-url origin 2>/dev/null | sed 's|.*github.com[:/]||;s|\.git$||' || true)"
    fi
    if [[ -z "$gh_repo" ]]; then
        gh_repo="$(gh api user -q .login 2>/dev/null || true)/$repo_name"
    fi
    echo "$gh_repo"
}

# --- subcommands ---

cmd_init() {
    local repo_name="$2" secrets_file="$1" visibility="$3" target_dir="${4:-$PWD}"
    local host_port="${5:-}"

    check_prereqs
    echo "=== Reading secrets from: $secrets_file ==="
    load_secrets "$secrets_file"

    local dh_user dh_token deploy_root
    dh_user="$(get_secret DOCKERHUB_USERNAME)"
    dh_token="$(get_secret DOCKERHUB_TOKEN)"
    deploy_root="$(get_secret DEPLOY_ROOT)"
    if [[ -z "$dh_user" || -z "$dh_token" ]]; then
        echo "Error: DOCKERHUB_USERNAME and DOCKERHUB_TOKEN must be set in $secrets_file" >&2
        exit 1
    fi
    if [[ -z "$deploy_root" ]]; then
        echo "Error: DEPLOY_ROOT must be set in $secrets_file" >&2
        exit 1
    fi

    local tmpl_dir="$FORGE_TEMPLATES_DIR"
    bootstrap_templates
    if [[ ! -d "$tmpl_dir/shared" ]]; then
        echo "Error: shared templates not found in $tmpl_dir" >&2
        exit 1
    fi

    local container_port=80
    local port
    port=$(port_assign "$repo_name" "$host_port")

    local image_name="$dh_user/$repo_name:dev"

    # Setup target directory
    echo ""
    echo "=== Setting up: $target_dir ==="
    if [[ "$target_dir" != "$PWD" ]]; then
        mkdir -p "$target_dir"
    fi
    cd "$target_dir"

    if [[ -d .git ]]; then
        echo "  Removing existing .git..."
        rm -rf .git
    fi

    # Render templates
    echo ""
    echo "=== Scaffolding project (port=$port) ==="

    mkdir -p .github/workflows

    render_template "$tmpl_dir/shared/Dockerfile" "Dockerfile" \
        "$image_name" "$repo_name" "$port" "$container_port" "$deploy_root"

    render_template "$tmpl_dir/shared/docker-compose.yml" "docker-compose.yml" \
        "$image_name" "$repo_name" "$port" "$container_port" "$deploy_root"

    render_template "$tmpl_dir/shared/deploy.yml" ".github/workflows/deploy.yml" \
        "$image_name" "$repo_name" "$port" "$container_port" "$deploy_root"

    render_template "$tmpl_dir/shared/index.html" "index.html" \
        "$image_name" "$repo_name" "$port" "$container_port" "$deploy_root"

    echo "  Dockerfile"
    echo "  docker-compose.yml"
    echo "  .github/workflows/deploy.yml"
    echo "  index.html"

    # Init git + commit
    echo ""
    echo "=== Initializing git repository ==="
    git init --quiet
    git branch -m main
    cat > README.md <<EOF
# $repo_name

Generated by forge — port: $port
EOF
    git add .
    git commit --quiet -m "forge: initial scaffold"

    # Create GitHub repo (no push yet — secrets must go first)
    echo "=== Creating GitHub repository: $repo_name ($visibility) ==="
    gh repo create "$repo_name" --"$visibility" --disable-issues --disable-wiki
    local gh_user gh_repo
    gh_user="$(gh api user -q .login 2>/dev/null)"
    gh_repo="$gh_user/$repo_name"

    # Register secrets BEFORE pushing so the workflow has them
    echo ""
    echo "=== Registering GitHub Secrets for: $gh_repo ==="
    set_github_secrets "$gh_repo"

    # Now push — workflow triggers with secrets available
    echo ""
    echo "=== Pushing to GitHub ==="
    gh auth setup-git --hostname github.com 2>/dev/null || true
    git remote get-url origin >/dev/null 2>&1 || git remote add origin "https://github.com/$gh_repo.git"
    git push -u origin main --quiet

    # Create Docker Hub repo
    echo ""
    echo "=== Creating Docker Hub repository: $dh_user/$repo_name ==="
    create_dockerhub_repo "$dh_user" "$repo_name" "$dh_token"

    echo ""
    echo "=== Done ==="
    echo "  Directory:     $target_dir"
    echo "  GitHub:        https://github.com/$gh_repo"
    echo "  Docker Hub:    https://hub.docker.com/r/$dh_user/$repo_name"
    echo "  Port:          $port"
}

cmd_sync() {
    local repo_name="$2" secrets_file="$1"

    check_prereqs
    echo "=== Reading secrets from: $secrets_file ==="
    load_secrets "$secrets_file"

    local gh_repo="$repo_name"
    if [[ -z "$gh_repo" ]]; then
        gh_repo="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)"
    fi
    if [[ -z "$gh_repo" ]]; then
        echo "Error: could not determine repo. Run from a git repo or use --name owner/repo." >&2
        exit 1
    fi

    echo ""
    echo "=== Syncing GitHub Secrets for: $gh_repo ==="
    set_github_secrets "$gh_repo"

    echo ""
    echo "=== Done ==="
    echo "  GitHub:        https://github.com/$gh_repo"
}

cmd_destroy() {
    local repo_name="$2" secrets_file="$1" visibility="$3" target_dir="${4:-$PWD}"

    check_prereqs
    echo "=== Reading secrets from: $secrets_file ==="
    load_secrets "$secrets_file"

    local dh_user dh_token deploy_root
    dh_user="$(get_secret DOCKERHUB_USERNAME)"
    dh_token="$(get_secret DOCKERHUB_TOKEN)"
    deploy_root="$(get_secret DEPLOY_ROOT)"
    if [[ -z "$dh_user" || -z "$dh_token" ]]; then
        echo "Error: DOCKERHUB_USERNAME and DOCKERHUB_TOKEN must be set in $secrets_file" >&2
        exit 1
    fi

    local gh_repo
    gh_repo="$(resolve_gh_repo "$target_dir" "$repo_name")"

    echo ""
    echo "This will permanently delete:"
    echo "  GitHub repo:   $gh_repo"
    echo "  Docker Hub:    $dh_user/$repo_name"
    echo "  Local dir:     $target_dir"
    echo "  NAS deploy:    $deploy_root/$repo_name"
    echo ""
    read -rp "Type 'yes' to confirm: " confirm
    if [[ "$confirm" != "yes" ]]; then
        echo "Aborted."
        exit 0
    fi

    # --- Phase 1: Remote cleanup via CI ---
    if [[ -d "$target_dir/.git" ]]; then
        echo ""
        echo "=== Phase 1: Remote cleanup via GitHub Actions ==="

        local tmpl_dir="$FORGE_TEMPLATES_DIR"
        bootstrap_templates

        mkdir -p "$target_dir/.github/workflows"

        if [[ -f "$tmpl_dir/shared/cleanup.yml" ]]; then
            sed "s|{{DEPLOY_ROOT}}|$deploy_root|g" \
                "$tmpl_dir/shared/cleanup.yml" > "$target_dir/.github/workflows/cleanup.yml"
        fi

        cd "$target_dir"
        git add .github/workflows/cleanup.yml
        git commit --quiet -m "forge: cleanup before destroy [skip ci]" || true
        gh auth setup-git --hostname github.com 2>/dev/null || true
        git push --quiet 2>&1 || true

        # Trigger cleanup workflow
        echo "  Triggering cleanup workflow..."
        gh workflow run cleanup.yml -R "$gh_repo" 2>&1 || echo "  Warning: could not trigger cleanup workflow" >&2

        # Poll for workflow completion
        echo "  Waiting for cleanup to complete..."
        local waited=0
        while [[ $waited -lt 120 ]]; do
            local status
            status=$(gh run list -R "$gh_repo" --workflow=cleanup.yml --limit 1 --json status,conclusion -q '.[0].status' 2>/dev/null || echo "")
            local conclusion
            conclusion=$(gh run list -R "$gh_repo" --workflow=cleanup.yml --limit 1 --json status,conclusion -q '.[0].conclusion' 2>/dev/null || echo "")
            if [[ "$status" == "completed" ]]; then
                echo "  Cleanup workflow: $conclusion"
                break
            fi
            sleep 5
            waited=$((waited + 5))
            if [[ $((waited % 15)) -eq 0 ]]; then
                echo "  ... waiting ($waited s)"
            fi
        done
        if [[ $waited -ge 120 ]]; then
            echo "  Warning: cleanup workflow timed out, proceeding anyway" >&2
        fi

        cd - >/dev/null
    else
        echo ""
        echo "=== Phase 1: Skipped (no local git repo) ==="
    fi

    # --- Phase 2: Delete remote repos ---
    echo ""
    echo "=== Phase 2: Deleting remote repositories ==="

    echo "=== Deleting GitHub repository: $gh_repo ==="
    if ! gh repo delete "$gh_repo" --yes 2>&1; then
        echo ""
        echo "Error: GitHub deletion failed (missing delete_repo scope?)." >&2
        echo "  Run: gh auth refresh -h github.com -s delete_repo" >&2
        echo "  Aborting — Docker Hub and local directory untouched." >&2
        exit 1
    fi

    echo ""
    echo "=== Deleting Docker Hub repository: $dh_user/$repo_name ==="
    delete_dockerhub_repo "$dh_user" "$repo_name" "$dh_token"

    # --- Phase 3: Remove local ---
    echo ""
    echo "=== Phase 3: Removing local directory ==="

    port_release "$repo_name"

    if [[ "$target_dir" == "$PWD" ]] || [[ "$PWD" == "$target_dir"/* ]]; then
        cd "$(dirname "$target_dir")"
    fi
    rm -rf "$target_dir"

    echo ""
    echo "=== Done ==="
}

# --- main ---

main() {
    local subcommand="${1:-}"
    shift 2>/dev/null || true

    case "$subcommand" in
        init|sync|destroy) ;;
        -h|--help) usage ;;
        "")
            echo "Error: expected subcommand 'init', 'sync', or 'destroy'" >&2
            usage ;;
        *)
            echo "Error: unknown subcommand '$subcommand'" >&2
            usage ;;
    esac

    local secrets_file="" repo_name="" visibility="private"
    local host_port="" project_name="" target_dir="$PWD"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --secrets)    secrets_file="$2"; shift 2 ;;
            --name)       repo_name="$2"; shift 2 ;;
            --port)       host_port="$2"; shift 2 ;;
            --visibility) visibility="$2"; shift 2 ;;
            -h|--help)    usage ;;
            -*)
                echo "Unknown option: $1" >&2
                usage ;;
            *)
                if [[ "$subcommand" =~ ^(init|destroy)$ && -z "$project_name" ]]; then
                    project_name="$1"; shift
                else
                    echo "Unexpected argument: $1" >&2
                    usage
                fi
                ;;
        esac
    done

    secrets_file="$(resolve_secrets_file "$secrets_file")"

    if [[ "$subcommand" =~ ^(init|destroy)$ ]]; then
        if [[ -n "$project_name" ]]; then
            target_dir="$PWD/$project_name"
        fi
        if [[ -z "$repo_name" ]]; then
            repo_name="$(basename "$target_dir")"
        fi
    fi

    "cmd_$subcommand" "$secrets_file" "$repo_name" "$visibility" "$target_dir" "$host_port"
}

main "$@"
